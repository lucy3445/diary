{
  "expo": {
    "name": "하루",
    "slug": "diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F1EBDF",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lucy3445.diary"
    },
    "android": {
      "package": "com.lucy3445.diary",
      "adaptiveIcon": {
        "backgroundColor": "#F1EBDF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "diary"
  }
}
